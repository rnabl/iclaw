{
  "name": "iclaw",
  "version": "0.1.0",
  "description": "iClaw - Open source iMessage AI Assistant framework",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules",
    "db:migrate": "pnpm --filter @iclaw/database migrate",
    "db:generate": "pnpm --filter @iclaw/database generate",
    "deploy:api": "pnpm --filter @iclaw/api deploy",
    "deploy:functions": "pnpm --filter @iclaw/database deploy:functions"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.3.0",
    "prettier": "^3.2.0",
    "eslint": "^8.56.0",
    "@types/node": "^20.11.0"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=18.0.0"
  }
}
